{
  "manifest_version": 3,
  "name": "Stellar Wallet SDK Demo",
  "version": "1.0.0",
  "description": "A demo wallet built with Stellar Wallet SDK.",
  "action": {
    "default_popup": "index.html",
    "default_title": "Stellar Wallet"
  },
  "permissions": ["storage"],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
